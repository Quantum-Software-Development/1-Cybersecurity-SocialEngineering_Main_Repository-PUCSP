# ============================================
# Generic .gitignore for Python projects
# ============================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
*.manifest
*.spec

# Virtual environments
.venv/
venv/
env/
ENV/
.venv*/
venv*/
env*/

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos.
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Translations
*.mo
*.pot

# Django stuff (safe in generic Python projects)
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask / local instance data
instance/
.webassets-cache/

# Scrapy stuff
.scrapy

# Sphinx documentation
docs/_build/
doc/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints/

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# PDM, Poetry, Hatch, Pipenv, etc. (lock/caches)
__pypackages__/
*.pdm.toml
poetry.lock
.pdm-python
.pdm-build/
.pdm-cache/
.pdm-venv/
Pipfile.lock

# Environment variables / secrets
.env
.env.*
*.env

# VS Code, PyCharm, and other IDE/editor settings
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# MacOS / Windows OS files
.DS_Store
Thumbs.db

# Mypy / type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff, pytype, pyre
.ruff_cache/
.pytype/
.pyre/

# Local databases (generic)
*.sqlite3
*.db

# Temporary / backup files
*.tmp
*.bak
*~
